SECRET_KEY=replace-with-long-random-secret
DATABASE_URL=sqlite:///askmarley.db
# Production (PythonAnywhere MySQL) example:
# DATABASE_URL=mysql+pymysql://USERNAME:PASSWORD@HOSTNAME/DB_NAME?charset=utf8mb4
FLASK_ENV=development
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Keep "legacy" for consumer/provider DB values, switch to "canonical" for buyer/seller.
ROLE_STORAGE_MODE=legacy
